# ============================================
# VERITAS AI — Environment Configuration
# ============================================

# Application
APP_NAME=VERITAS AI
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=VERITAS AI

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=veritas123

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Upload
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# Demo
DEMO_ADMIN_PASSWORD=veritas123
DEMO_ANALYST_PASSWORD=analyst123
